{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./scripts/verify.sh)",
      "Bash(.venv/bin/pytest:*)",
      "Bash(.venv/bin/ruff:*)",
      "Bash(.venv/bin/python -m pytest:*)",
      "Bash(.venv/bin/python -m ruff:*)",
      "Bash(.venv/bin/python scripts/docs_sync.py)",
      "Bash(.venv/bin/python benchmarks/run.py:*)",
      "Bash(.venv/bin/rtgs:*)"
    ]
  }
}
